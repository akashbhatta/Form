# Copy this file's structure into Vercel Project Settings > Environment Variables.
# Do NOT commit a real .env file with actual values to your git repository.

# Found in Supabase Dashboard > Project Settings > API > Project URL
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Found in Supabase Dashboard > Project Settings > API > Project API keys > anon / public
# This is the PUBLIC key — safe to expose in frontend code because Row Level
# Security (RLS) restricts what it can actually do (insert-only, no reads).
SUPABASE_ANON_KEY=your-anon-public-key-here

# NEVER put your service_role / secret key in this project. It is not needed
# for this form and must never appear in frontend code, this repo, or Vercel
# client-exposed env vars.
